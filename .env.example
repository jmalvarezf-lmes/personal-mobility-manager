TOYOTA_USERNAME=
TOYOTA_PASSWORD=
TOYOTA_LOCALE=es-es
DEFAULT_LICENSE_PLATE=

# PostgreSQL connection DSN
POSTGRES_DSN=postgresql://mobility:mobility@localhost:5432/mobility_manager

# Madrid Callejero CSV URL
MADRID_CALLEJERO_URL=https://datos.madrid.es/dataset/200075-0-callejero/resource/200075-1-callejero-csv/download/200075-1-callejero-csv.csv

# Ingestion interval in hours (default: 24)
INGESTION_INTERVAL_HOURS=24

# OpenStreetMap self-hosted tile server URL (leave empty to use public OSM tiles via the frontend fallback)
OSM_TILE_URL=

# Allowed CORS origins for the frontend (comma-separated)
CORS_ORIGINS=http://localhost:5173
